# --- DATABASE ---
# Use PostgreSQL for production. aiosqlite can be used for local quick tests.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neuroplan

# --- SECURITY ---
# Generate a secure key using `openssl rand -hex 32`
SECRET_KEY=yoursecretkeyhere
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI CONFIGURATION ---
# Primary engine. Set to 'ollama' for local or 'openai'/'groq' for cloud.
AI_ENGINE=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Optional: OpenAI or Groq API Keys if using cloud fallbacks
OPENAI_API_KEY=
GROQ_API_KEY=

# --- REDIS (CACHING) ---
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# --- PERFORMANCE & FEATURES ---
DKT_ENABLED=true
USE_CUSTOM_AI=false
CUSTOM_AI_URL=

# --- PROJECT METADATA ---
PROJECT_NAME=NeuroPlan-AI
API_V1_STR=/api/v1
